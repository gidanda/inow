{
  "expo": {
    "name": "inow",
    "slug": "inow",
    "scheme": "inow",
    "version": "1.0.0",
    "jsEngine": "jsc",
    "orientation": "portrait",
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.inow"
    }
  }
}
